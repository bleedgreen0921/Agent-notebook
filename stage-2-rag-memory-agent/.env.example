LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace-with-your-api-key
LLM_MODEL=replace-with-your-model-name
LLM_TIMEOUT_MS=30000

# local 使用本地哈希向量，openai 使用兼容的 /embeddings 接口。
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=256

AGENT_MAX_STEPS=12
AGENT_TIMEOUT_MS=180000
TOOL_TIMEOUT_MS=15000
CONTEXT_MAX_CHARS=60000
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.10

AGENT_DATA_DIR=.agent-data
AGENT_WORKSPACE_ROOT=.
SEARCH_API_URL=https://zh.wikipedia.org/w/api.php

# 受限代码工具默认关闭；理解 docs/02-tools.md 的风险后再开启。
ENABLE_CODE_EXECUTION=false
